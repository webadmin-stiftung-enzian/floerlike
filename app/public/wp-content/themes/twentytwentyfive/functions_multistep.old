// Adds theme support for post formats.
if (! function_exists('twentytwentyfive_post_format_setup')) :
	/**
	 * Adds theme support for post formats.
	 *
	 * @since Twenty Twenty-Five 1.0
	 *
	 * @return void
	 */
	function twentytwentyfive_post_format_setup()
	{
		add_theme_support('post-formats', array('aside', 'audio', 'chat', 'gallery', 'image', 'link', 'quote', 'status', 'video'));
	}
endif;
add_action('after_setup_theme', 'twentytwentyfive_post_format_setup');

// Enqueues editor-style.css in the editors.
if (! function_exists('twentytwentyfive_editor_style')) :
	/**
	 * Enqueues editor-style.css in the editors.
	 *
	 * @since Twenty Twenty-Five 1.0
	 *
	 * @return void
	 */
	function twentytwentyfive_editor_style()
	{
		add_editor_style('assets/css/editor-style.css');
	}
endif;
add_action('after_setup_theme', 'twentytwentyfive_editor_style');

// Enqueues the theme stylesheet on the front.
if (! function_exists('twentytwentyfive_enqueue_styles')) :
	/**
	 * Enqueues the theme stylesheet on the front.
	 *
	 * @since Twenty Twenty-Five 1.0
	 *
	 * @return void
	 */
	function twentytwentyfive_enqueue_styles()
	{
		$suffix = SCRIPT_DEBUG ? '' : '.min';
		$src    = 'style' . $suffix . '.css';

		wp_enqueue_style(
			'twentytwentyfive-style',
			get_parent_theme_file_uri($src),
			array(),
			wp_get_theme()->get('Version')
		);
		wp_style_add_data(
			'twentytwentyfive-style',
			'path',
			get_parent_theme_file_path($src)
		);
	}
endif;
add_action('wp_enqueue_scripts', 'twentytwentyfive_enqueue_styles');

// Registers custom block styles.
if (! function_exists('twentytwentyfive_block_styles')) :
	/**
	 * Registers custom block styles.
	 *
	 * @since Twenty Twenty-Five 1.0
	 *
	 * @return void
	 */
	function twentytwentyfive_block_styles()
	{
		register_block_style(
			'core/list',
			array(
				'name'         => 'checkmark-list',
				'label'        => __('Checkmark', 'twentytwentyfive'),
				'inline_style' => '
				ul.is-style-checkmark-list {
					list-style-type: "\2713";
				}

				ul.is-style-checkmark-list li {
					padding-inline-start: 1ch;
				}',
			)
		);
	}
endif;
add_action('init', 'twentytwentyfive_block_styles');

// Registers pattern categories.
if (! function_exists('twentytwentyfive_pattern_categories')) :
	/**
	 * Registers pattern categories.
	 *
	 * @since Twenty Twenty-Five 1.0
	 *
	 * @return void
	 */
	function twentytwentyfive_pattern_categories()
	{

		register_block_pattern_category(
			'twentytwentyfive_page',
			array(
				'label'       => __('Pages', 'twentytwentyfive'),
				'description' => __('A collection of full page layouts.', 'twentytwentyfive'),
			)
		);

		register_block_pattern_category(
			'twentytwentyfive_post-format',
			array(
				'label'       => __('Post formats', 'twentytwentyfive'),
				'description' => __('A collection of post format patterns.', 'twentytwentyfive'),
			)
		);
	}
endif;
add_action('init', 'twentytwentyfive_pattern_categories');

// Registers block binding sources.
if (! function_exists('twentytwentyfive_register_block_bindings')) :
	/**
	 * Registers the post format block binding source.
	 *
	 * @since Twenty Twenty-Five 1.0
	 *
	 * @return void
	 */
	function twentytwentyfive_register_block_bindings()
	{
		register_block_bindings_source(
			'twentytwentyfive/format',
			array(
				'label'              => _x('Post format name', 'Label for the block binding placeholder in the editor', 'twentytwentyfive'),
				'get_value_callback' => 'twentytwentyfive_format_binding',
			)
		);
	}
endif;
add_action('init', 'twentytwentyfive_register_block_bindings');

// Registers block binding callback function for the post format name.
if (! function_exists('twentytwentyfive_format_binding')) :
	/**
	 * Callback function for the post format name block binding source.
	 *
	 * @since Twenty Twenty-Five 1.0
	 *
	 * @return string|void Post format name, or nothing if the format is 'standard'.
	 */
	function twentytwentyfive_format_binding()
	{
		$post_format_slug = get_post_format();

		if ($post_format_slug && 'standard' !== $post_format_slug) {
			return get_post_format_string($post_format_slug);
		}
	}
endif;

defined('ABSPATH') || exit;


// =============================================================================
// Floerlike: Checkout Liefermethode (Versand / Abholung)
//
// Fügt nach dem Kontakt-Schritt einen neuen Schritt "Liefermethode" ein, in dem
// der Kunde wählt, ob er die Bestellung geliefert oder im Laden abholt.
// Lieferung ist nur im Stadtgebiet Zürich möglich (WC-Versandzone).
// =============================================================================

// ---------------------------------------------------------------------------
// 0. Fluid Checkout Pro: eingebaute Local-Pickup-Funktion deaktivieren, damit
//    unsere eigene Implementierung nicht mit FC Pro's Hooks kollidiert.
// ---------------------------------------------------------------------------
add_filter('pre_option_fc_enable_checkout_local_pickup', '__return_empty_string');

/**
 * 1. Neuen Checkout-Schritt "Liefermethode" (Priorität 15) registrieren –
 *    liegt zwischen Kontakt (10) und Versand (20).
 *    Außerdem wird die Shipping-Address-Substep konditionell ausgeblendet und
 *    als "abgeschlossen" markiert, wenn Abholung gewählt wurde.
 */
add_action('fc_register_steps', 'floerlike_register_delivery_type_step');
function floerlike_register_delivery_type_step()
{
	if (! class_exists('FluidCheckout_Steps')) {
		return;
	}

	$fc = FluidCheckout_Steps::instance();

	$fc->register_checkout_step(array(
		'step_id'                      => 'liefermethode',
		'step_title'                   => _x('Liefermethode', 'Checkout-Schritttitel', 'floerlike'),
		'proceed_to_step_button_label' => __('Weiter zur Liefermethode', 'floerlike'),
		'priority'                     => 15,
	));

	$fc->register_checkout_substep('liefermethode', array(
		'substep_id'                  => 'liefermethode_choice',
		'substep_title'               => __('Lieferoption wählen', 'floerlike'),
		'priority'                    => 10,
		'render_fields_callback'      => 'floerlike_render_delivery_type_fields',
		'render_review_text_callback' => 'floerlike_render_delivery_type_review_text',
		'is_complete_callback'        => 'floerlike_is_delivery_type_complete',
	));
}

/**
 * 2. Shipping-Address-Substep: ausblenden und als abgeschlossen markieren,
 *    wenn Abholung gewählt wurde.
 *    Der Filter fc_register_checkout_substep_args wird beim Registrieren jeder
 *    Substep aufgerufen – wir prüfen daher step_id und substep_id.
 */
add_filter('fc_register_checkout_substep_args', 'floerlike_modify_shipping_address_substep', 10, 2);
function floerlike_modify_shipping_address_substep($substep_args, $step_id)
{
	if ('shipping' !== $step_id || ! isset($substep_args['substep_id'])) {
		return $substep_args;
	}

	$substep_id = $substep_args['substep_id'];

	// --- Versandmethode: immer rendern, Sichtbarkeit via data-substep-visible ---
	// Kein render_condition_callback: der Substep muss immer im DOM bleiben, damit
	// JS data-substep-visible umschalten kann. Bei Abholung wird er per CSS-Attribut
	// ausgeblendet (initial via floerlike_shipping_method_initial_visibility) und
	// via toggleShippingMethodSubstep() dynamisch ein-/ausgeblendet.
	if ('shipping_method' === $substep_id) {
		// Bei Abholung gilt dieser Substep immer als abgeschlossen.
		$orig_complete = isset($substep_args['is_complete_callback'])
			? $substep_args['is_complete_callback']
			: null;
		$substep_args['is_complete_callback'] = function () use ($orig_complete) {
			$delivery_type = WC()->session ? WC()->session->get('floerlike_delivery_type', 'shipping') : 'shipping';
			if ('local_pickup' === $delivery_type) {
				return true;
			}
			if ($orig_complete && is_callable($orig_complete)) {
				return call_user_func($orig_complete);
			}
			return false;
		};
		return $substep_args;
	}

	if ('shipping_address' !== $substep_id) {
		return $substep_args;
	}

	// --- Lieferadresse: immer anzeigen, Inhalt je nach Liefermethode ---

	// Substep immer rendern – bei Abholung wird Abholadresse angezeigt.
	$substep_args['render_condition_callback'] = '__return_true';

	// Felder: Abholadresse oder Versandadressformular.
	$orig_fields = isset($substep_args['render_fields_callback'])
		? $substep_args['render_fields_callback']
		: null;

	$substep_args['render_fields_callback'] = function ($step_id, $substep_id) use ($orig_fields) {
		$delivery_type = WC()->session ? WC()->session->get('floerlike_delivery_type', 'shipping') : 'shipping';
		echo '<div id="floerlike-shipping-content">';
		if ('local_pickup' === $delivery_type) {
			floerlike_render_pickup_address_block();
		} elseif ($orig_fields && is_callable($orig_fields)) {
			call_user_func($orig_fields, $step_id, $substep_id);
		}
		echo '</div>';
	};

	// Abgeschlossen: bei Abholung immer true, sonst Original-Callback.
	$orig_complete = isset($substep_args['is_complete_callback'])
		? $substep_args['is_complete_callback']
		: null;

	$substep_args['is_complete_callback'] = function () use ($orig_complete) {
		$delivery_type = WC()->session ? WC()->session->get('floerlike_delivery_type', 'shipping') : 'shipping';
		if ('local_pickup' === $delivery_type) {
			return true;
		}
		if ($orig_complete && is_callable($orig_complete)) {
			return call_user_func($orig_complete);
		}
		return false;
	};

	return $substep_args;
}

// ---------------------------------------------------------------------------
// 2a. Versandschritt immer rendern
//     Bei Abholung zeigt er Abholadresse statt Formular.
// ---------------------------------------------------------------------------

add_filter('fc_register_checkout_step_args', 'floerlike_keep_shipping_step_visible', 10, 1);
function floerlike_keep_shipping_step_visible($step_args)
{
	if (! isset($step_args['step_id']) || 'shipping' !== $step_args['step_id']) {
		return $step_args;
	}
	$step_args['render_condition_callback'] = '__return_true';
	return $step_args;
}

// ---------------------------------------------------------------------------
// 2b. Abholadresse – Hilfsfunktionen
// ---------------------------------------------------------------------------

function floerlike_get_pickup_address()
{
	$country_raw  = get_option('woocommerce_default_country', '');
	$country_key  = strstr($country_raw, ':', true) ?: $country_raw;
	$countries    = WC()->countries ? WC()->countries->get_countries() : array();
	$country_name = isset($countries[$country_key]) ? $countries[$country_key] : $country_key;
	return array(
		'address'   => get_option('woocommerce_store_address', ''),
		'address_2' => get_option('woocommerce_store_address_2', ''),
		'city'      => get_option('woocommerce_store_city', ''),
		'postcode'  => get_option('woocommerce_store_postcode', ''),
		'country'   => $country_name,
	);
}

function floerlike_render_pickup_address_block()
{
	$addr        = floerlike_get_pickup_address();
	$has_address = ! empty($addr['address']) || ! empty($addr['city']);
	echo '<div class="floerlike-pickup-address-block">';
	if ($has_address) {
		echo '<address class="floerlike-pickup-address">';
		echo esc_html($addr['address']);
		if ($addr['address_2']) {
			echo '<br>' . esc_html($addr['address_2']);
		}
		echo '<br>' . esc_html(trim($addr['postcode'] . ' ' . $addr['city']));
		if ($addr['country']) {
			echo '<br>' . esc_html($addr['country']);
		}
		echo '</address>';
	} else {
		echo '<p class="floerlike-pickup-placeholder">'
			. esc_html__('Abholadresse wird noch hinterlegt – bitte kontaktieren Sie uns.', 'floerlike')
			. '</p>';
	}
	echo '</div>';
}

// Substep-Titel dynamisch je nach Liefermethode.
add_filter('fc_substep_title_shipping_address', 'floerlike_shipping_address_title');
function floerlike_shipping_address_title($title)
{
	$delivery_type = WC()->session ? WC()->session->get('floerlike_delivery_type', 'shipping') : 'shipping';
	return 'local_pickup' === $delivery_type ? __('Abholadresse', 'floerlike') : $title;
}

// Initialen data-substep-visible-Wert für den Versandmethode-Substep setzen.
// So ist der Substep beim Seitenaufruf korrekt versteckt, wenn Abholung gewählt wurde,
// ohne dass er aus dem DOM entfernt wird (das würde das Umschalten blockieren).
add_filter('fc_substep_shipping_method_attributes', 'floerlike_shipping_method_initial_visibility');
function floerlike_shipping_method_initial_visibility($attrs)
{
	if (! is_array($attrs)) {
		$attrs = array();
	}
	$delivery_type = WC()->session ? WC()->session->get('floerlike_delivery_type', 'shipping') : 'shipping';
	if ('local_pickup' === $delivery_type) {
		$attrs['data-substep-visible'] = 'no';
	}
	return $attrs;
}

// Fragmente: Titel, Felder-Inhalt und Review-Text nach update_checkout aktualisieren.
add_filter('woocommerce_update_order_review_fragments', 'floerlike_shipping_address_substep_fragments', 20);
function floerlike_shipping_address_substep_fragments($fragments)
{
	if (! WC()->session) {
		return $fragments;
	}
	$delivery_type = WC()->session->get('floerlike_delivery_type', 'shipping');

	// Titel-Fragment.
	$title = 'local_pickup' === $delivery_type
		? __('Abholadresse', 'floerlike')
		: __('Lieferadresse', 'floerlike');
	$fragments['.fc-step__substep-title--shipping_address'] =
		'<h3 class="fc-step__substep-title fc-step__substep-title--shipping_address">' . esc_html($title) . '</h3>';

	// Felder-Inhalt-Fragment.
	ob_start();
	echo '<div id="floerlike-shipping-content">';
	if ('local_pickup' === $delivery_type) {
		floerlike_render_pickup_address_block();
	} elseif (class_exists('FluidCheckout_Steps') && method_exists(FluidCheckout_Steps::instance(), 'output_substep_shipping_address_fields')) {
		FluidCheckout_Steps::instance()->output_substep_shipping_address_fields('shipping', 'shipping_address');
	}
	echo '</div>';
	$fragments['#floerlike-shipping-content'] = ob_get_clean();

	// Review-Text-Fragment (bei Abholung Adresse statt eingegebener Adresse zeigen).
	if ('local_pickup' === $delivery_type) {
		$addr        = floerlike_get_pickup_address();
		$has_address = ! empty($addr['address']) || ! empty($addr['city']);
		$html = '<div class="fc-step__substep-text-content fc-step__substep-text-content--shipping_address">';
		if ($has_address) {
			$line = trim(
				$addr['address']
					. ($addr['address_2'] ? ', ' . $addr['address_2'] : '')
					. ', ' . trim($addr['postcode'] . ' ' . $addr['city'])
			);
			$html .= '<div class="fc-step__substep-text-line">' . esc_html($line) . '</div>';
		} else {
			$html .= '<div class="fc-step__substep-text-line">'
				. esc_html__('Abholadresse wird noch hinterlegt.', 'floerlike')
				. '</div>';
		}
		$html .= '</div>';
		$fragments['.fc-step__substep-text-content--shipping_address'] = $html;
	} else {
		// Bei gewöhnlicher Lieferung: Original Fluid Checkout Review-Text für Shipping Address ausgeben
		if (class_exists('FluidCheckout_Steps')) {
			$fragments['.fc-step__substep-text-content--shipping_address'] = FluidCheckout_Steps::instance()->get_substep_text_shipping_address();
		}
	}

	return $fragments;
}

// ---------------------------------------------------------------------------
// Substep-Ausgabe: Auswahl-Felder
// ---------------------------------------------------------------------------

function floerlike_render_delivery_type_fields()
{
	$current = WC()->session ? WC()->session->get('floerlike_delivery_type', 'shipping') : 'shipping';
?>
	<div class="floerlike-delivery-type-options">
		<label class="floerlike-delivery-option<?php echo 'shipping' === $current ? ' floerlike-delivery-option--selected' : ''; ?>">
			<input type="radio" name="floerlike_delivery_type" value="shipping"
				<?php checked($current, 'shipping'); ?>>
			<span class="floerlike-delivery-option__label"><?php esc_html_e('Lieferung nach Hause', 'floerlike'); ?></span>
			<span class="floerlike-delivery-option__hint"><?php esc_html_e('Nur im Stadtgebiet Zürich verfügbar', 'floerlike'); ?></span>
		</label>
		<label class="floerlike-delivery-option<?php echo 'local_pickup' === $current ? ' floerlike-delivery-option--selected' : ''; ?>">
			<input type="radio" name="floerlike_delivery_type" value="local_pickup"
				<?php checked($current, 'local_pickup'); ?>>
			<span class="floerlike-delivery-option__label"><?php esc_html_e('Im Laden abholen', 'floerlike'); ?></span>
			<span class="floerlike-delivery-option__hint"><?php esc_html_e('Kostenlos – kein Versand nötig', 'floerlike'); ?></span>
		</label>
	</div>
<?php
}

function floerlike_render_delivery_type_review_text()
{
	$current = WC()->session ? WC()->session->get('floerlike_delivery_type', 'shipping') : 'shipping';
	$label   = 'local_pickup' === $current
		? esc_html__('Im Laden abholen', 'floerlike')
		: esc_html__('Lieferung nach Hause', 'floerlike');
	echo '<div class="fc-step__substep-text-content fc-step__substep-text-content--liefermethode_choice">';
	echo '<div class="fc-step__substep-text-line">' . $label . '</div>';
	echo '</div>';
}

add_filter('woocommerce_update_order_review_fragments', 'floerlike_delivery_type_review_fragment');
function floerlike_delivery_type_review_fragment($fragments)
{
	ob_start();
	floerlike_render_delivery_type_review_text();
	$fragments['.fc-step__substep-text-content--liefermethode_choice'] = ob_get_clean();
	return $fragments;
}

function floerlike_is_delivery_type_complete()
{
	// Kein Fallback-Default: der Schritt gilt erst als abgeschlossen, wenn der
	// Kunde explizit eine Option gewählt hat (Session-Wert gesetzt). Alle anderen
	// Funktionen nutzen 'shipping' als Default, damit WC-Berechnungen schon vor
	// der Auswahl korrekt laufen – dieser Callback erzwingt die aktive Wahl.
	$value = WC()->session ? WC()->session->get('floerlike_delivery_type') : null;
	return in_array($value, array('shipping', 'local_pickup'), true);
}

// ---------------------------------------------------------------------------
// 3. Gewählte Liefermethode in der WC-Session speichern
// ---------------------------------------------------------------------------

add_action('woocommerce_checkout_update_order_review', 'floerlike_save_delivery_type_to_session');
function floerlike_save_delivery_type_to_session($posted_data)
{
	$data = array();
	parse_str($posted_data, $data);

	if (
		isset($data['floerlike_delivery_type'])
		&& in_array($data['floerlike_delivery_type'], array('shipping', 'local_pickup'), true)
	) {
		$new_type = $data['floerlike_delivery_type'];
		$old_type = WC()->session->get('floerlike_delivery_type');
		WC()->session->set('floerlike_delivery_type', $new_type);

		// Bei Wechsel der Liefermethode: gewählte Versandmethode und Shipping-Cache
		// zurücksetzen, damit WooCommerce die Tarife neu berechnet.
		if ($new_type !== $old_type) {
			WC()->session->set('chosen_shipping_methods', array());
			WC_Cache_Helper::invalidate_cache_group('shipping');
		}
	}
}

// ---------------------------------------------------------------------------
// 4. Warenkorb benötigt keinen Versand bei Abholung
//    → WooCommerce versteckt den Versand-Schritt und überspringt die Validierung.
// ---------------------------------------------------------------------------

add_filter('woocommerce_cart_needs_shipping', 'floerlike_cart_needs_shipping');
function floerlike_cart_needs_shipping($needs_shipping)
{
	if (! WC()->session) {
		return $needs_shipping;
	}
	$delivery_type = WC()->session->get('floerlike_delivery_type', 'shipping');
	if ('local_pickup' === $delivery_type) {
		return false;
	}
	return $needs_shipping;
}

// ---------------------------------------------------------------------------
// 5. Versand-Tarife filtern: Abholmethoden aus Lieferungs-Paketen entfernen
//    (relevant wenn "Lieferung" gewählt ist)
// ---------------------------------------------------------------------------

add_filter('woocommerce_package_rates', 'floerlike_filter_shipping_rates', 10, 2);
function floerlike_filter_shipping_rates($rates, $package)
{
	if (! WC()->session) {
		return $rates;
	}
	$delivery_type = WC()->session->get('floerlike_delivery_type', 'shipping');

	// Bei gewählter Lieferung: Abholmethoden entfernen, damit nur echte
	// Versandoptionen erscheinen und die Zürich-Prüfung greift.
	if ('shipping' === $delivery_type) {
		$pickup_ids = array('local_pickup', 'pickup_location');
		foreach ($rates as $key => $rate) {
			if (in_array($rate->get_method_id(), $pickup_ids, true)) {
				unset($rates[$key]);
			}
		}
	}

	return $rates;
}

// ---------------------------------------------------------------------------
// 6. Meldung wenn Lieferung für die eingegebene Adresse nicht möglich ist
//    (Adresse ausserhalb der Zürcher Versandzone)
//
//    Best Practice: Wir befragen WooCommerces eigenes Shipping-Zone-System
//    (WC_Shipping_Zones::get_zone_matching_package) anstatt die PLZ mit einem
//    hartcodierten Regex zu prüfen. So bleibt die Logik automatisch in Sync
//    mit den in WooCommerce hinterlegten Versandzonen.
//
//    Zone 0 ("Rest of the World") bedeutet: keine konfigurierte Zone hat die
//    Adresse gematcht. Wenn Zone 0 zusätzlich keine aktiven Versandmethoden
//    hat, liegt die Adresse definitiv ausserhalb unseres Liefergebiets.
// ---------------------------------------------------------------------------

add_filter('woocommerce_no_shipping_available_html', 'floerlike_no_delivery_zone_message');
function floerlike_no_delivery_zone_message($html)
{
	if (! is_checkout() || ! WC()->session || ! WC()->customer) {
		return $html;
	}
	$delivery_type = WC()->session->get('floerlike_delivery_type', 'shipping');
	if ('shipping' !== $delivery_type) {
		return $html;
	}

	if (! class_exists('WC_Shipping_Zones')) {
		return $html;
	}

	// Lieferadresse ermitteln, Fallback auf Rechnungsadresse.
	$postcode = WC()->customer->get_shipping_postcode();
	if (empty($postcode)) {
		$postcode = WC()->customer->get_billing_postcode();
	}
	if (empty(trim($postcode))) {
		return $html;
	}

	$country = WC()->customer->get_shipping_country();
	if (empty($country)) {
		$country = WC()->customer->get_billing_country();
	}
	// Länderschlüssel bereinigen (z. B. "CH:ZH" → "CH").
	if (strpos($country, ':') !== false) {
		$country = strstr($country, ':', true);
	}
	if (empty($country)) {
		$country = strstr(get_option('woocommerce_default_country', 'CH'), ':', true)
			?: get_option('woocommerce_default_country', 'CH');
	}

	$state = WC()->customer->get_shipping_state() ?: '';

	// WooCommerce-API: passende Versandzone für diese Adresse ermitteln.
	$package = array(
		'destination'     => array(
			'country'  => $country,
			'state'    => $state,
			'postcode' => trim($postcode),
		),
		'contents'        => array(),
		'contents_cost'   => 0,
		'applied_coupons' => array(),
	);

	$zone = WC_Shipping_Zones::get_zone_matching_package($package);

	// Keine spezifische Zone gefunden → Zone 0 ("Rest of the World").
	// Wenn Zone 0 auch keine aktiven Versandmethoden hat, ist die Adresse
	// ausserhalb unseres Liefergebiets.
	if ($zone instanceof WC_Shipping_Zone && 0 === $zone->get_id()) {
		$methods = $zone->get_shipping_methods(true); // true = nur aktivierte Methoden
		if (empty($methods)) {
			return '<p class="woocommerce-error floerlike-zone-error">'
				. esc_html__('Für Ihre Adresse ist leider keine Lieferung möglich. Wir liefern ausschliesslich im Stadtgebiet Zürich. Bitte wählen Sie die Liefermethode «Im Laden abholen».', 'floerlike')
				. '</p>';
		}
	}

	// Eine konkrete Zone hat gematcht (oder Zone 0 hat Methoden) → Standard-WC-Meldung.
	return $html;
}

// ---------------------------------------------------------------------------
// 7. Validierung beim Abschicken des Checkouts
// ---------------------------------------------------------------------------

add_action('woocommerce_checkout_process', 'floerlike_validate_delivery_type');
function floerlike_validate_delivery_type()
{
	// phpcs:ignore WordPress.Security.NonceVerification.Missing -- WooCommerce Checkout nonce
	$delivery_type = isset($_POST['floerlike_delivery_type'])
		? sanitize_text_field(wp_unslash($_POST['floerlike_delivery_type']))
		: '';

	if (! in_array($delivery_type, array('shipping', 'local_pickup'), true)) {
		wc_add_notice(
			__('Bitte wählen Sie eine Liefermethode (Lieferung oder Abholung).', 'floerlike'),
			'error'
		);
	}
}

// ---------------------------------------------------------------------------
// 8. Liefermethode als Meta-Datum an der Bestellung speichern
// ---------------------------------------------------------------------------

add_action('woocommerce_checkout_create_order', 'floerlike_save_delivery_type_to_order', 10, 2);
function floerlike_save_delivery_type_to_order($order, $data)
{
	$delivery_type = WC()->session ? WC()->session->get('floerlike_delivery_type') : '';
	if ($delivery_type) {
		$order->update_meta_data('_floerlike_delivery_type', sanitize_text_field($delivery_type));
	}
}

// Liefermethode in der Bestellübersicht im Admin-Bereich anzeigen.
add_action('woocommerce_admin_order_data_after_shipping_address', 'floerlike_display_delivery_type_in_admin', 10);
function floerlike_display_delivery_type_in_admin($order)
{
	$delivery_type = $order->get_meta('_floerlike_delivery_type');
	if (! $delivery_type) {
		return;
	}
	$label = 'local_pickup' === $delivery_type
		? __('Im Laden abholen', 'floerlike')
		: __('Lieferung nach Hause', 'floerlike');
	echo '<p><strong>' . esc_html__('Liefermethode:', 'floerlike') . '</strong> ' . esc_html($label) . '</p>';
}

// ---------------------------------------------------------------------------
// 9. JavaScript: Auswahl aktualisiert den WC-Checkout via update_checkout
// ---------------------------------------------------------------------------

add_action('wp_enqueue_scripts', 'floerlike_enqueue_checkout_scripts', 20);
function floerlike_enqueue_checkout_scripts()
{
	if (! is_checkout()) {
		return;
	}

	$js = "(function ($) {
	'use strict';

	function toggleShippingMethodSubstep() {
		var val = $('input[name=\"floerlike_delivery_type\"]:checked').val();
		var \$substep = $('.fc-step__substep[data-substep-id=\"shipping_method\"]');
		if (val === 'local_pickup') {
			\$substep.attr('data-substep-visible', 'no');
		} else {
			\$substep.attr('data-substep-visible', 'yes');
		}
	}

	var deliveryTypeTimer;

	// Wählt-Klasse setzen, Sichtbarkeit umschalten und WooCommerce-Checkout aktualisieren.
	// Debounce verhindert mehrfache parallele AJAX-Requests bei schnellem Umschalten.
	$(document).on('change', 'input[name=\"floerlike_delivery_type\"]', function () {
		$('.floerlike-delivery-option').removeClass('floerlike-delivery-option--selected');
		$(this).closest('.floerlike-delivery-option').addClass('floerlike-delivery-option--selected');
		toggleShippingMethodSubstep();
		clearTimeout(deliveryTypeTimer);
		deliveryTypeTimer = setTimeout(function () {
			$(document.body).trigger('update_checkout');
		}, 200);
	});

	// Wählt-Klasse und Sichtbarkeit nach Fragment-Refresh wiederherstellen.
	$(document.body).on('updated_checkout', function () {
		$('input[name=\"floerlike_delivery_type\"]:checked')
			.closest('.floerlike-delivery-option')
			.addClass('floerlike-delivery-option--selected');
		toggleShippingMethodSubstep();
	});

	// Initialer Aufruf zur Sicherheit.
	$(function() {
		toggleShippingMethodSubstep();
	});
}(jQuery));";

	wp_add_inline_script('wc-checkout', $js);
}

// ---------------------------------------------------------------------------
// 10. CSS für die Liefermethoden-Auswahl
// ---------------------------------------------------------------------------

add_action('wp_head', 'floerlike_checkout_styles', 99);
function floerlike_checkout_styles()
{
	if (! is_checkout()) {
		return;
	}
?>
	<style id="floerlike-checkout-delivery-css">
		.floerlike-delivery-type-options {
			display: flex;
			gap: 1rem;
			margin: .5rem 0 1rem;
		}

		.floerlike-delivery-option {
			position: relative;
			flex: 1;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: .3rem;
			padding: 1.25rem 1rem;
			border: 2px solid #d0d0d0;
			border-radius: .5rem;
			cursor: pointer;
			transition: border-color .15s ease, background-color .15s ease;
			text-align: center;
		}

		.floerlike-delivery-option input[type="radio"] {
			position: absolute;
			opacity: 0;
			pointer-events: none;
		}

		.floerlike-delivery-option:hover,
		.floerlike-delivery-option--selected {
			border-color: #1a1a1a;
			background-color: #f6f6f6;
		}

		.floerlike-delivery-option__label {
			font-weight: 600;
			font-size: 1rem;
		}

		.floerlike-delivery-option__hint {
			font-size: .8125rem;
			color: #666;
		}

		.floerlike-zone-error {
			margin-top: .75rem;
		}

		.floerlike-pickup-address-block {
			padding: .75rem 1rem;
			background: #f6f6f6;
			border: 1px solid #ddd;
			border-radius: .375rem;
			margin-bottom: .5rem;
		}

		.floerlike-pickup-address {
			font-style: normal;
			line-height: 1.7;
		}

		.floerlike-pickup-placeholder {
			color: #888;
			font-style: italic;
			margin: 0;
		}
	</style>
<?php
}
