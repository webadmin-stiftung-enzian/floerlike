{
	"apiVersion": 3,
	"name": "woo-order-ext/checkout-newsletter-subscription",
	"version": "2.0.0",
	"title": "Newsletter Subscription!",
	"category": "woocommerce",
	"description": "Adds a newsletter subscription checkbox to the checkout.",
	"supports": {
		"html": false,
		"align": false,
		"multiple": false,
		"reusable": false
	},
	"attributes": {
		"lock": {
			"type": "object",
			"default": {
				"remove": false,
				"move": false
			}
		},
		"optInDefaultChecked": {
			"type": "boolean",
			"default": false
		},
		"text": {
			"type": "string",
			"default": "Subscribe to our newsletter"
		}
	},
	"parent": [ "woocommerce/checkout-fields-block", "woocommerce/checkout-totals-block" ],
	"textdomain": "woo-order-ext",
	"editorStyle": "file:../../../build/style-woo-order-ext-checkout-newsletter-subscription-block.css"
}
